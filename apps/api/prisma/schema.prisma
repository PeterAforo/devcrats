generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// AUTH & USERS
// ========================

enum UserRole {
  super_admin
  estate_manager
  landlord
  tenant
  security_staff
  maintenance_staff
  viewer
}

enum IdType {
  ghana_card
  passport
}

enum OccupancyType {
  self_occupied
  rented
}

enum ChangeRequestStatus {
  pending
  approved
  rejected
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  avatarUrl     String?   @map("avatar_url")
  avatarRequired Boolean  @default(true) @map("avatar_required")
  idType        IdType?   @map("id_type")
  idNumber      String?   @map("id_number")
  role          UserRole  @default(tenant)
  emailVerified Boolean   @default(false) @map("email_verified")
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")
  mfaSecret     String?   @map("mfa_secret")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  resetToken    String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  estateId      String?   @map("estate_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estate        Estate?        @relation(fields: [estateId], references: [id])
  refreshTokens RefreshToken[]
  loginAttempts LoginAttempt[]
  notifications Notification[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  landlord      Landlord?
  tenant        Tenant?
  staffMember   Staff?

  @@index([email])
  @@index([estateId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model LoginAttempt {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  email     String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  success   Boolean
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([userId])
  @@map("login_attempts")
}

model Invitation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String
  role      UserRole
  estateId  String   @map("estate_id") @db.Uuid
  token     String   @unique
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  invitedBy String   @map("invited_by") @db.Uuid
  acceptedAt DateTime? @map("accepted_at")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  estate Estate @relation(fields: [estateId], references: [id])

  @@index([token])
  @@index([email])
  @@map("invitations")
}

// ========================
// ESTATES & PROPERTIES
// ========================

model Estate {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  address     String
  city        String?
  state       String?
  country     String?
  postalCode  String? @map("postal_code")
  latitude    Float?
  longitude   Float?
  logoUrl     String? @map("logo_url")
  description String?
  timezone    String  @default("UTC")
  currency    String  @default("GHS")
  rules       String?
  isActive    Boolean @default(true) @map("is_active")

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users       User[]
  clusters    Cluster[]
  buildings   Building[]
  invitations Invitation[]
  amenities   EstateAmenity[]
  landlords   Landlord[]
  tenants     Tenant[]
  feeComponents  FeeComponent[]
  feeSchedules   FeeSchedule[]
  invoices       Invoice[]
  complaints     Complaint[]
  notifications  Notification[]
  serviceRequests ServiceRequest[]
  visitors       VisitorInvite[]
  gateLogs       GateLog[]
  vehicles       Vehicle[]
  meters         Meter[]
  documents      Document[]
  staff          Staff[]
  vendors        Vendor[]
  auditLogs      AuditLog[]
  specialLevies  SpecialLevy[]

  @@index([name])
  @@map("estates")
}

model Cluster {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  estateId String  @map("estate_id") @db.Uuid
  code     String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estate    Estate    @relation(fields: [estateId], references: [id])
  buildings Building[]

  @@unique([estateId, name])
  @@index([estateId])
  @@map("clusters")
}

model Building {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  estateId  String  @map("estate_id") @db.Uuid
  clusterId String? @map("cluster_id") @db.Uuid
  address   String?
  floors    Int     @default(1)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estate    Estate   @relation(fields: [estateId], references: [id])
  cluster   Cluster? @relation(fields: [clusterId], references: [id])
  units     Unit[]

  @@index([estateId])
  @@index([clusterId])
  @@map("buildings")
}

enum UnitStatus {
  vacant
  occupied
  under_maintenance
  reserved
}

enum UnitType {
  studio
  one_bed
  two_bed
  three_bed
  penthouse
  commercial
}

model Unit {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitNumber    String     @map("unit_number")
  houseNumber   String?    @map("house_number")
  buildingId    String     @map("building_id") @db.Uuid
  floor         Int        @default(1)
  unitType      UnitType   @default(one_bed) @map("unit_type")
  status        UnitStatus @default(vacant)
  sizeSqft      Float?     @map("size_sqft")
  bedrooms      Int        @default(1)
  bathrooms     Int        @default(1)
  features      Json?
  rentAmount    Decimal?   @map("rent_amount") @db.Decimal(12, 2)
  floorPlanUrl  String?    @map("floor_plan_url")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  building      Building        @relation(fields: [buildingId], references: [id])
  leases        Lease[]
  unitHistory   UnitHistory[]
  feeAssignments UnitFeeAssignment[]
  invoices      Invoice[]
  serviceRequests ServiceRequest[]
  complaints    Complaint[]
  meters        Meter[]
  documents     Document[]
  ownerships    PropertyOwnership[]

  @@unique([buildingId, unitNumber])
  @@index([buildingId])
  @@index([status])
  @@map("units")
}

model UnitHistory {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId   String @map("unit_id") @db.Uuid
  action   String
  details  Json?
  actorId  String? @map("actor_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId])
  @@map("unit_history")
}

model Amenity {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique
  description String?
  icon        String?

  createdAt DateTime @default(now()) @map("created_at")

  estates EstateAmenity[]

  @@map("amenities")
}

model EstateAmenity {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estateId String @map("estate_id") @db.Uuid
  amenityId String @map("amenity_id") @db.Uuid
  isActive  Boolean @default(true) @map("is_active")

  estate  Estate  @relation(fields: [estateId], references: [id])
  amenity Amenity @relation(fields: [amenityId], references: [id])

  @@unique([estateId, amenityId])
  @@map("estate_amenities")
}

// ========================
// LANDLORDS & TENANTS
// ========================

model Landlord {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String  @unique @map("user_id") @db.Uuid
  estateId      String  @map("estate_id") @db.Uuid
  bankName      String? @map("bank_name")
  bankAccountNo String? @map("bank_account_no")
  bankAccountName String? @map("bank_account_name")
  bankCode      String? @map("bank_code")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user       User    @relation(fields: [userId], references: [id])
  estate     Estate  @relation(fields: [estateId], references: [id])
  leases     Lease[]
  payouts    LandlordPayout[]
  properties PropertyOwnership[]

  @@index([estateId])
  @@map("landlords")
}

model Tenant {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @unique @map("user_id") @db.Uuid
  estateId          String  @map("estate_id") @db.Uuid
  landlordId        String? @map("landlord_id") @db.Uuid
  emergencyContact  String? @map("emergency_contact")
  emergencyPhone    String? @map("emergency_phone")
  employerName      String? @map("employer_name")
  employerPhone     String? @map("employer_phone")
  idType            IdType? @map("id_type")
  idNumber          String? @map("id_number")
  idDocumentUrl     String? @map("id_document_url")
  dateOfBirth       DateTime? @map("date_of_birth")
  nationality       String?  @default("Ghanaian")
  occupation        String?
  addedByLandlord   Boolean @default(false) @map("added_by_landlord")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user            User    @relation(fields: [userId], references: [id])
  estate          Estate  @relation(fields: [estateId], references: [id])
  leases          Lease[]
  payments        Payment[]
  complaints      Complaint[]
  serviceRequests ServiceRequest[]
  visitorInvites  VisitorInvite[]
  familyMembers   FamilyMember[]
  changeRequests  TenantChangeRequest[]

  @@index([estateId])
  @@index([landlordId])
  @@map("tenants")
}

model FamilyMember {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  relationship String
  dateOfBirth  DateTime? @map("date_of_birth")
  phone        String?
  photoUrl     String?   @map("photo_url")
  idType       IdType?   @map("id_type")
  idNumber     String?   @map("id_number")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("family_members")
}

model TenantChangeRequest {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  field       String
  oldValue    String?             @map("old_value")
  newValue    String              @map("new_value")
  reason      String?
  status      ChangeRequestStatus @default(pending)
  reviewedBy  String?             @map("reviewed_by") @db.Uuid
  reviewedAt  DateTime?           @map("reviewed_at")
  reviewNote  String?             @map("review_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("tenant_change_requests")
}

model PropertyOwnership {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  landlordId    String        @map("landlord_id") @db.Uuid
  unitId        String        @map("unit_id") @db.Uuid
  occupancyType OccupancyType @default(self_occupied) @map("occupancy_type")
  acquiredDate  DateTime?     @map("acquired_date")
  isActive      Boolean       @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  landlord Landlord @relation(fields: [landlordId], references: [id])
  unit     Unit     @relation(fields: [unitId], references: [id])

  @@unique([landlordId, unitId])
  @@index([landlordId])
  @@index([unitId])
  @@map("property_ownerships")
}

enum LeaseStatus {
  draft
  pending_signature
  active
  expired
  terminated
  renewed
}

model Lease {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId        String      @map("unit_id") @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  landlordId    String      @map("landlord_id") @db.Uuid
  status        LeaseStatus @default(draft)
  rentAmount    Decimal     @map("rent_amount") @db.Decimal(12, 2)
  startDate     DateTime    @map("start_date")
  endDate       DateTime    @map("end_date")
  terms         String?
  depositAmount Decimal?    @map("deposit_amount") @db.Decimal(12, 2)
  depositStatus String?     @map("deposit_status")
  signedAt      DateTime?   @map("signed_at")
  terminatedAt  DateTime?   @map("terminated_at")
  terminationReason String? @map("termination_reason")

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  unit     Unit     @relation(fields: [unitId], references: [id])
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  landlord Landlord @relation(fields: [landlordId], references: [id])

  @@index([unitId])
  @@index([tenantId])
  @@index([landlordId])
  @@index([status])
  @@map("leases")
}

// ========================
// EMF (ESTATE MANAGEMENT FEE)
// ========================

enum ChargeType {
  fixed
  per_unit
  per_sqft
  percentage_of_rent
  tiered
}

enum FeeComponentCategory {
  utility
  security
  cleaning
  administration
  insurance
  reserve_fund
  amenity
  infrastructure
  special_levy
}

enum BillingFrequency {
  monthly
  quarterly
  semi_annually
  annually
  one_time
}

model FeeComponent {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estateId      String               @map("estate_id") @db.Uuid
  name          String
  description   String?
  category      FeeComponentCategory
  chargeType    ChargeType           @map("charge_type")
  amount        Decimal              @db.Decimal(12, 2)
  frequency     BillingFrequency
  isActive      Boolean              @default(true) @map("is_active")
  isSuspended   Boolean              @default(false) @map("is_suspended")
  suspendedReason String?            @map("suspended_reason")
  justification String?
  metadata      Json?

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estate    Estate @relation(fields: [estateId], references: [id])
  scheduleComponents FeeScheduleComponent[]
  documents FeeComponentDocument[]
  waivers   FeeWaiver[]
  disputes  FeeDispute[]
  invoices  ComponentInvoice[]

  @@index([estateId])
  @@index([category])
  @@map("fee_components")
}

model FeeComponentDocument {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feeComponentId String @map("fee_component_id") @db.Uuid
  fileName       String @map("file_name")
  fileUrl        String @map("file_url")
  fileType       String @map("file_type")

  createdAt DateTime @default(now()) @map("created_at")

  feeComponent FeeComponent @relation(fields: [feeComponentId], references: [id])

  @@map("fee_component_documents")
}

enum FeeScheduleStatus {
  draft
  notice_published
  active
  archived
}

model FeeSchedule {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estateId      String            @map("estate_id") @db.Uuid
  name          String
  status        FeeScheduleStatus @default(draft)
  effectiveDate DateTime?         @map("effective_date")
  noticeDate    DateTime?         @map("notice_date")
  version       Int               @default(1)
  changelog     String?

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estate     Estate @relation(fields: [estateId], references: [id])
  components FeeScheduleComponent[]
  versions   FeeScheduleVersion[]
  unitAssignments UnitFeeAssignment[]

  @@index([estateId])
  @@index([status])
  @@map("fee_schedules")
}

model FeeScheduleVersion {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feeScheduleId  String @map("fee_schedule_id") @db.Uuid
  version        Int
  data           Json
  changelog      String?
  createdBy      String? @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  feeSchedule FeeSchedule @relation(fields: [feeScheduleId], references: [id])

  @@index([feeScheduleId])
  @@map("fee_schedule_versions")
}

model FeeScheduleComponent {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feeScheduleId  String  @map("fee_schedule_id") @db.Uuid
  feeComponentId String  @map("fee_component_id") @db.Uuid
  landlordSplit  Decimal @default(0) @map("landlord_split") @db.Decimal(5, 2)
  tenantSplit    Decimal @default(100) @map("tenant_split") @db.Decimal(5, 2)

  feeSchedule  FeeSchedule  @relation(fields: [feeScheduleId], references: [id])
  feeComponent FeeComponent @relation(fields: [feeComponentId], references: [id])

  @@unique([feeScheduleId, feeComponentId])
  @@map("fee_schedule_components")
}

model UnitFeeAssignment {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId        String @map("unit_id") @db.Uuid
  feeScheduleId String @map("fee_schedule_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  unit        Unit        @relation(fields: [unitId], references: [id])
  feeSchedule FeeSchedule @relation(fields: [feeScheduleId], references: [id])

  @@unique([unitId, feeScheduleId])
  @@map("unit_fee_assignments")
}

model SpecialLevy {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estateId      String  @map("estate_id") @db.Uuid
  name          String
  description   String?
  amount        Decimal @db.Decimal(12, 2)
  justification String?
  installments  Int     @default(1)
  isActive      Boolean @default(true) @map("is_active")

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estate Estate @relation(fields: [estateId], references: [id])

  @@index([estateId])
  @@map("special_levies")
}

model FeeWaiver {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feeComponentId String   @map("fee_component_id") @db.Uuid
  unitId         String   @map("unit_id") @db.Uuid
  reason         String
  startDate      DateTime @map("start_date")
  endDate        DateTime? @map("end_date")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  feeComponent FeeComponent @relation(fields: [feeComponentId], references: [id])

  @@map("fee_waivers")
}

model FeeDispute {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feeComponentId String  @map("fee_component_id") @db.Uuid
  raisedBy       String  @map("raised_by") @db.Uuid
  query          String
  response       String?
  status         String  @default("open")
  resolvedAt     DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  feeComponent FeeComponent @relation(fields: [feeComponentId], references: [id])

  @@map("fee_disputes")
}

model ComponentInvoice {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feeComponentId String  @map("fee_component_id") @db.Uuid
  vendorName     String? @map("vendor_name")
  invoiceNumber  String? @map("invoice_number")
  amount         Decimal @db.Decimal(12, 2)
  fileUrl        String? @map("file_url")
  period         String?
  notes          String?

  createdAt DateTime @default(now()) @map("created_at")

  feeComponent FeeComponent @relation(fields: [feeComponentId], references: [id])

  @@map("component_invoices")
}

model ReserveFundTransaction {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estateId    String  @map("estate_id") @db.Uuid
  type        String
  amount      Decimal @db.Decimal(12, 2)
  description String?
  reference   String?

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@index([estateId])
  @@map("reserve_fund_transactions")
}

// ========================
// PAYMENTS & FINANCIALS
// ========================

enum InvoiceStatus {
  draft
  sent
  paid
  partially_paid
  overdue
  cancelled
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
  partially_paid
}

enum PaymentMethod {
  bank_transfer
  card
  mobile_money
  cash
}

model Invoice {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estateId      String        @map("estate_id") @db.Uuid
  unitId        String?       @map("unit_id") @db.Uuid
  tenantId      String?       @map("tenant_id") @db.Uuid
  invoiceNumber String        @unique @map("invoice_number")
  type          String
  status        InvoiceStatus @default(draft)
  subtotal      Decimal       @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  amountPaid    Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  dueDate       DateTime      @map("due_date")
  issuedDate    DateTime      @default(now()) @map("issued_date")
  paidDate      DateTime?     @map("paid_date")
  notes         String?

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estate   Estate    @relation(fields: [estateId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@index([estateId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
