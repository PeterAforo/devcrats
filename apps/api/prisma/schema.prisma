  createdAt DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([number])
  @@map("receipts")
}

model Expense {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estateId    String  @map("estate_id") @db.Uuid
  category    String
  description String
  amount      Decimal @db.Decimal(12, 2)
  vendorId    String? @map("vendor_id") @db.Uuid
  receiptUrl  String? @map("receipt_url")
  date        DateTime

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([estateId])
  @@map("expenses")
}

model LandlordPayout {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  landlordId   String  @map("landlord_id") @db.Uuid
  grossAmount  Decimal @map("gross_amount") @db.Decimal(12, 2)
  managementFee Decimal @map("management_fee") @db.Decimal(12, 2)
  netAmount    Decimal @map("net_amount") @db.Decimal(12, 2)
  period       String
  status       String  @default("pending")
