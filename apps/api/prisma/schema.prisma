enum ServiceRequestStatus {
  submitted
  acknowledged
  assigned
  in_progress
  pending_approval
  completed
  closed
}

enum ServiceRequestPriority {
  critical
  high
  normal
  low
}

enum ServiceRequestCategory {
  plumbing
  electrical
  structural
  appliance
  pest_control
  hvac
  general
  emergency
}

model ServiceRequest {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estateId    String                 @map("estate_id") @db.Uuid
  unitId      String?                @map("unit_id") @db.Uuid
  tenantId    String?                @map("tenant_id") @db.Uuid
  title       String
  description String
  category    ServiceRequestCategory
  priority    ServiceRequestPriority @default(normal)
  status      ServiceRequestStatus   @default(submitted)
  assignedTo  String?                @map("assigned_to") @db.Uuid
  estimatedCost Decimal?             @map("estimated_cost") @db.Decimal(12, 2)
  actualCost    Decimal?             @map("actual_cost") @db.Decimal(12, 2)
  rating        Int?
  ratingComment String?              @map("rating_comment")
  completedAt   DateTime?            @map("completed_at")

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  estate      Estate  @relation(fields: [estateId], references: [id])
  unit        Unit?   @relation(fields: [unitId], references: [id])
  tenant      Tenant? @relation(fields: [tenantId], references: [id])
  attachments ServiceRequestAttachment[]

  @@index([estateId])
  @@index([status])
  @@index([priority])
  @@map("service_requests")
}

model ServiceRequestAttachment {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceRequestId String @map("service_request_id") @db.Uuid
  fileName         String @map("file_name")
  fileUrl          String @map("file_url")
  fileType         String @map("file_type")
  stage            String @default("before")

  createdAt DateTime @default(now()) @map("created_at")

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id])

  @@map("service_request_attachments")
}

model MaintenanceSchedule {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estateId    String   @map("estate_id") @db.Uuid
  title       String
  description String?
  frequency   String
  nextDueDate DateTime @map("next_due_date")
  lastDoneAt  DateTime? @map("last_done_at")
  assignedTo  String?  @map("assigned_to") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([estateId])
  @@map("maintenance_schedules")
}

