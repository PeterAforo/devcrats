# ─── Core ────────────────────────────────────────────────
NODE_ENV="production"
DATABASE_URL="postgresql://user:pass@host/estateiq?sslmode=require"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-change-in-production"
PORT=4000
CORS_ORIGINS="https://devcrats-api.vercel.app,http://localhost:3000"
FRONTEND_URL="https://devcrats-api.vercel.app"
API_URL="https://estateiq-api.vercel.app"

# ─── Payment Gateways ────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_live_..."
PAYSTACK_PUBLIC_KEY="pk_live_..."
PAYSTACK_CALLBACK_URL="https://devcrats-api.vercel.app/dashboard/payments"
HUBTEL_CLIENT_ID=""
HUBTEL_CLIENT_SECRET=""
HUBTEL_MERCHANT_ACCOUNT=""

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@estateiq.app"
EMAIL_FROM_NAME="EstateIQ"

# ─── SMS (mNotify) ──────────────────────────────────────
MNOTIFY_API_KEY=""
MNOTIFY_SENDER_ID="EstateIQ"

# ─── File Storage (Vercel Blob) ─────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ─── Maps & Location ────────────────────────────────────
GOOGLE_MAPS_API_KEY=""
